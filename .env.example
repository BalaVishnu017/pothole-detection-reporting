# =============================================================================
# InfraVision AI — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual credentials below
#   3. NEVER commit .env to Git — it is already in .gitignore
# =============================================================================

# --- Email Configuration (Gmail recommended) ---
# The Gmail address used to send automated reports
SENDER_EMAIL=balavls918@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=bsipnhijmsgbshny

# The recipient email (road department or authority)
ROAD_DEPT_EMAIL=balavishnu017@gmail.com 

# --- Application Configuration ---
# YOLO model confidence threshold (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.5

# Pothole area ratio threshold to classify as "critical" (0.0 to 1.0)
CRITICAL_AREA_RATIO=0.05

# --- Database ---
# Path to the SQLite database file
DATABASE_PATH=data/users.db

# --- GPS ---
# Default GPS coordinates (used as fallback if device GPS is unavailable)
DEFAULT_LATITUDE=17.3913
DEFAULT_LONGITUDE=78.3206
